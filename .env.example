# =====================================================================
# FormLLC — Next.js environment variables
# Copy to .env.local for local dev, or configure on Hostinger Cloud panel.
# =====================================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://formllc.us
NEXT_PUBLIC_SITE_NAME=FormLLC

# ---- Google reCAPTCHA v2 (checkbox) ----
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ---- SMTP (Gmail Workspace App Password recommended) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@formllc.us
SMTP_PASS=
MAIL_FROM_NAME=FormLLC

# ---- Admin recipients ----
ADMIN_TO=contact@formllc.us
ADMIN_CC=aziz@formllc.us
ADMIN_NAME=FormLLC Support

# ---- Blog Admin ----
BLOG_ADMIN_TOKEN=8f3c2b2c9f2a8c6a4d7e0c9a1b6f8d2e9c5a7b1d4f6e8a9c0b2d3e4f5a6b7c8d

# ---- MySQL — Global (formllc.us) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u202126396_modformllc
DB_USER=u202126396_modformllc
DB_PASS=

# ---- MySQL — US region (formllc.us/us) ----
US_DB_HOST=localhost
US_DB_PORT=3306
US_DB_NAME=u202126396_usformllc
US_DB_USER=u202126396_usformllc
US_DB_PASS=

# ---- Mailchimp ----
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_STATUS=subscribed

# ---- Google Sheets webhook (Apps Script) ----
SHEETS_WEBAPP_URL=
SHEETS_TOKEN=

# ---- Meta Conversions API ----
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_CODE=

# ---- PayPal ----
PAYPAL_CHECKOUT_URL=https://www.paypal.com/instantcommerce/checkout/EVHLN6X5YYQG4
# Optional: PayPal API credentials for server-side order creation (TODO: implement)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=live

# ---- Tax intake — secure file download links ----
DOWNLOAD_SECRET=please-change-to-a-long-random-32+-char-string
TAX_INTAKE_UPLOAD_DIR=./public/uploads/tax-intake

# ---- Spam / dupe protection ----
DUPLICATE_BLOCK_WINDOW_SECONDS=120